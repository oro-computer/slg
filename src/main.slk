test "slg e2e - concurrency options accept auto keyword" {
  let av_opt: ArgvOwned? =
    argv_alloc(
      "slg",
      "--jobs", "auto",
      "--split-depth=auto",
      "--queue-cap", "auto",
      "--target-jobs", "auto",
      "--max-jobs-total", "AUTO",
      "--file-batch=auto",
      "-F",
      "TODO",
      "testdata/basic"
    );
