test "slg e2e - -l regex prefix scan avoids false positives" {
  // Regression test: in `-l` mode the engine may scan an initial prefix of a
  // large file. If the prefix ends mid-line, regex patterns like `foo$` must
  // not match based on the truncated line.
  //
  // This constructs a file where the first `probe` bytes end with `needle`,
  // but the line continues past the probe. The regex `needle$` should not
  // match the full file.

  let probe: i64 = 16384; // `slg::engine::READ_SCRATCH_PROBE` (duplicated here on purpose).
  let needle: string = "SLG_E2E_ANCHOR_TEST_12345";
  let pat: string = "SLG_E2E_ANCHOR_TEST_12345$";

  let path: string = "testdata/basic/anchor_long_line.txt";

  let needle_len: i64 = std::runtime::mem::string_len(needle);
  assert(needle_len > 0, "needle should be non-empty");
  assert(needle_len < probe, "needle must fit in probe");

  let total_len: i64 = probe + 16;
  let buf: u64 = std::runtime::mem::alloc(total_len);
  assert(buf != 0, "alloc failed");

  // Fill with 'a'.
  var i: i64 = 0;
  while i < total_len {
    std::runtime::mem::store_u8(buf, i, 97); // 'a'
    i = i + 1;
  }

  // Place `needle` at the end of the probe.
  let needle_ptr: u64 = std::runtime::mem::string_ptr(needle);
  let start: i64 = probe - needle_len;
  var j: i64 = 0;
  while j < needle_len {
    let b: u8 = std::runtime::mem::load_u8(needle_ptr, j);
    std::runtime::mem::store_u8(buf, start + j, b);
    j = j + 1;
  }

  // Ensure the file continues past the probe and does not end in `needle`.
  std::runtime::mem::store_u8(buf, probe, 120); // 'x'

  let fd: int =
  std::runtime::posix::fs::open(
    path,
    std::runtime::posix::fs::O_WRONLY | std::runtime::posix::fs::O_CREAT | std::runtime::posix::fs::O_TRUNC,
    420 // 0644
  ) as int;
  assert(fd >= 0, "open failed");
  let ok_write: bool = write_all_fd(fd, buf, total_len);
  let _ = std::runtime::posix::fs::close(fd);
  std::runtime::mem::free(buf);
  assert(ok_write, "write failed");

  // Run `slg -l`.
  let av_opt: ArgvOwned? = argv_alloc("slg", "-l", pat, "testdata/basic");
  assert(av_opt != None, "argv alloc failed");
  let mut av: ArgvOwned = av_opt ?? ArgvOwned{ argc: 0, argv: 0 };

  let args: Args = Args.init(av.argc, av.argv);
  let cfg_opt: Config? = parse_cli(args);
  assert(cfg_opt != None, "parse_cli should succeed");

  let cap_opt: Capture? = match (cfg_opt) {
    Some(cfg) => await capture_stdout_run_cfg(cfg),
    None => None,
  };
  assert(cap_opt != None, "capture failed");
  let mut cap: Capture = cap_opt ?? Capture{ code: 2, out: BufferU8.empty() };

  // Cleanup before assertions (so failures don't leave test files behind).
  let _ = std::runtime::posix::fs::unlink(path);

  assert(cap.code == 1, "expected exit code 1 (no match)");
  let out_s: string = buffer_as_string(cap.out);
  assert(!contains(out_s, "anchor_long_line.txt"), "should not report a false match");

  cap.drop();
  av.drop();
}
